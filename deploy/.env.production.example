# 复制到项目根目录为 .env 后编辑（勿提交 .env）
# 无 HTTPS：./deploy/server-release.sh
# 有 HTTPS：USE_HTTPS=1 ./deploy/server-release.sh  然后  ./deploy/first-cert.sh
# 续期：crontab 加  0 4 * * * /opt/selfblog/deploy/renew-certs.sh
#
# 若密码等含 # 或空格，请用引号：POSTGRES_PASSWORD='xxx#yyy'

POSTGRES_PASSWORD=SelfBlog#2026

# 生产环境必须改为随机长串（与 docker-dev / dev-change 不同）
JWT_SECRET=SelfBlog#2026

# 公网访问 API 的根 URL（无尾部斜杠）
PUBLIC_URL=https://api.boboo.tech

# 浏览器里会访问管理端、官网的源，逗号分隔
CORS_ORIGINS=https://admin.boboo.tech,https://boboo.tech

# 可选：修改默认种子管理员（仅首次 seed 创建用户时生效；已有库不会改密码）
# ADMIN_SEED_USER=admin
# ADMIN_SEED_PASSWORD=请改为强密码

# ---- Nginx + certbot（USE_HTTPS=1 时必填；域名须已解析到本机公网 IP）----
# LE_DOMAIN=api.boboo.tech
# LE_EMAIL=you@example.com
