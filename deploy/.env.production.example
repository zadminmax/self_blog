# 复制到项目根目录为 .env 后编辑（勿提交 .env）
# 无 HTTPS：./deploy/server-release.sh
# 有 HTTPS：USE_HTTPS=1 ./deploy/server-release.sh  然后  ./deploy/first-cert.sh
# 续期：crontab 加  0 4 * * * /opt/selfblog/deploy/renew-certs.sh
#
# 若密码含 # 或空格，必须用引号，否则 # 后面会被当成注释截断：
# POSTGRES_PASSWORD='xxx#yyy'

POSTGRES_PASSWORD=请改为强密码

# 生产环境必须改为随机长串
JWT_SECRET=请改为至少32位随机串

# 公网访问 API 的根 URL（无尾部斜杠）；HTTPS 就绪后改为 https://
PUBLIC_URL=https://api.example.com

# 浏览器里会访问管理端、官网的源，逗号分隔
CORS_ORIGINS=https://admin.example.com,https://www.example.com

# 可选：修改默认种子管理员（仅首次 seed 创建用户时生效；已有库不会改密码）
# ADMIN_SEED_USER=admin
# ADMIN_SEED_PASSWORD=请改为强密码

# ---- Nginx + certbot（USE_HTTPS=1 时必填；勿注释；域名 A 记录须指向本机公网 IP）----
LE_DOMAIN=api.example.com
LE_EMAIL=you@example.com
