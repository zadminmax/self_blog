# 复制到项目根目录为 .env 后编辑（勿提交 .env）
#
# 服务器流程（仅此一种）:
#   1) 本机 ./deploy/build.sh 后 rsync 整个仓库（含 deploy/artifacts）
#   2) 服务器: ./deploy/up.sh
#   3) 首次 HTTPS: ./deploy/cert-init.sh
#   4) 续期 crontab: 0 4 * * * /opt/selfblog/deploy/cert-renew.sh >>/var/log/selfblog-cert.log 2>&1
#
# 若密码含 # 或空格，必须用引号，否则 # 后面会被当成注释截断：
# POSTGRES_PASSWORD='xxx#yyy'
# API 使用 DB_PASSWORD 分项注入（见 docker-compose.prod.yml），密码可含 # @ $ : 等，不再拼进 DATABASE_URL。

POSTGRES_PASSWORD=请改为强密码

# 生产环境必须改为随机长串
JWT_SECRET=请改为至少32位随机串

# 公网访问 API 的根 URL（无尾部斜杠），须为 https://
PUBLIC_URL=https://api.example.com

# 浏览器访问管理端、官网的源，逗号分隔，须与真实域名一致
CORS_ORIGINS=https://admin.example.com,https://www.example.com

# 可选：修改默认种子管理员（仅首次 seed 创建用户时生效；已有库不会改密码）
# ADMIN_SEED_USER=admin
# ADMIN_SEED_PASSWORD=请改为强密码

# ---- 域名与证书（三项均必填；DNS A 记录指向本机公网 IP；80/443 放行）----
LE_DOMAIN=api.example.com
LE_EMAIL=you@example.com
SITE_ADMIN_HOST=admin.example.com
SITE_WWW_HOST=www.example.com
